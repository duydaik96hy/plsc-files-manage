{
  "name": "plsc-files-manage-service",
  "version": "1.0.0",
  "description": "No description would cause a npm warning on build agent",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "scripts": {
    "build:dev": "tsc",
    "build:qa": "tsc",
    "build:prod": "tsc",
    "tsc": "tsc --watch",
    "lint": "eslint ./src/**/*.{js,ts} --fix",
    "lint:ci": "eslint ./src/**/*.{js,ts}",
    "logs": "pm2 log --merge-logs --lines 500 --time",
    "status": "pm2 monit",
    "test": "npm run lint & jest",
    "test:ci": "jest --ci --coverage --verbose",
    "prestart": "npm run build:dev",
    "start": "pm2 start ./dist/index.js & pm2 set pm2:autorestart true & pm2 save & pm2 logs index [--lines 1000]"
  },
  "dependencies": {
    "body-parser": "^1.19.0",
    "dayjs": "^1.11.7",
    "express": "^4.17.1",
    "js-base64": "^3.7.5",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.22",
    "@types/jest": "^26.0.21",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^4.19.0",
    "@typescript-eslint/parser": "^4.19.0",
    "eslint": "^7.22.0",
    "jest": "^29.7.0",
    "jest-junit": "^12.0.0",
    "pm2": "^6.0.6",
    "ts-jest": "^29.3.4",
    "typescript": "^4.2.3"
  }
}
